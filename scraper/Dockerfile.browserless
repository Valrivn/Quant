FROM browserless/chrome:latest

ENV MAX_CONCURRENT_SESSIONS=5
ENV MAX_QUEUE_LENGTH=10
ENV KEEP_ALIVE=true
ENV PREBOOT_CHROME=true
ENV PRERENDER_CHROME=true
ENV CHROME_REVISION=120

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD node -e "const http = require('http'); http.get('http://localhost:3000/pressure', (res) => process.exit(res.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"